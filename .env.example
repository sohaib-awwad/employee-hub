# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# These are the variables the app actually reads (see app.ts, index.ts, lib/db).

# ── Database (lib/db, node-postgres) ──────────────────────────────────────────
# PostgreSQL connection string. Required by the API server and migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/employee_hub

# ── API server (artifacts/api-server) ─────────────────────────────────────────
# Port the Express API listens on. Required.
PORT=5000

# Secret used to sign the session cookie. Any long random string works locally;
# in production set a real secret, e.g. `openssl rand -hex 32`.
COOKIE_SECRET=dev-only-change-me

# Production CORS allow-list: the exact browser origin of the frontend
# (e.g. https://employee-hub.example.com). Leave unset in local dev — the
# request origin is reflected and the Vite proxy handles same-origin calls.
# CLIENT_ORIGIN=

# Pino log level: trace | debug | info | warn | error (default: info).
# LOG_LEVEL=info

# ── Frontend dev server (artifacts/hr-portal, Vite) ───────────────────────────
# The frontend calls the API at the relative path /api. In local dev the Vite
# dev server proxies /api to this target (default http://localhost:5000).
# API_PROXY_TARGET=http://localhost:5000

# Base path the SPA is served under (default: /). Set when hosting under a
# sub-path. The Vite dev/build also reads PORT for the frontend port.
# BASE_PATH=/
